# Port the server will listen on (optional, defaults to 3001 when not set)
PORT=3000

# Secret key used to sign JWT tokens. Change this to a secure random string.
JWT_KEY=your_jwt_secret_here

# PostgreSQL connection string used by Prisma (see prisma/schema.prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/librarydb"

